{
  "$defs": {
    "AgentStageResult": {
      "additionalProperties": false,
      "properties": {
        "agent_name": {
          "title": "Agent Name",
          "type": "string"
        },
        "evidence": {
          "items": {
            "additionalProperties": {
              "type": "string"
            },
            "type": "object"
          },
          "title": "Evidence",
          "type": "array"
        },
        "status": {
          "$ref": "#/$defs/AgentStatus"
        },
        "summary": {
          "title": "Summary",
          "type": "string"
        }
      },
      "required": [
        "agent_name",
        "status",
        "summary"
      ],
      "title": "AgentStageResult",
      "type": "object"
    },
    "AgentStatus": {
      "enum": [
        "PENDING",
        "RUNNING",
        "COMPLETED",
        "DEGRADED",
        "BLOCKED",
        "FAILED"
      ],
      "title": "AgentStatus",
      "type": "string"
    },
    "CorrelationMetadata": {
      "additionalProperties": false,
      "properties": {
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "idempotency_key": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Idempotency Key"
        },
        "request_id": {
          "title": "Request Id",
          "type": "string"
        },
        "session_id": {
          "title": "Session Id",
          "type": "string"
        },
        "trace_id": {
          "title": "Trace Id",
          "type": "string"
        }
      },
      "title": "CorrelationMetadata",
      "type": "object"
    },
    "DriftItem": {
      "additionalProperties": false,
      "properties": {
        "current_pct": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Current Pct"
        },
        "drift_pct": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Drift Pct"
        },
        "key": {
          "title": "Key",
          "type": "string"
        },
        "target_pct": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Target Pct"
        },
        "tolerance_pct": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Tolerance Pct"
        },
        "within_tolerance": {
          "title": "Within Tolerance",
          "type": "boolean"
        }
      },
      "required": [
        "key",
        "current_pct",
        "target_pct",
        "drift_pct",
        "tolerance_pct",
        "within_tolerance"
      ],
      "title": "DriftItem",
      "type": "object"
    },
    "ExecutionProposalResponse": {
      "additionalProperties": false,
      "properties": {
        "confidence": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              },
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              }
            ]
          },
          "title": "Confidence",
          "type": "object"
        },
        "estimated_cost": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "default": "0",
          "title": "Estimated Cost"
        },
        "estimated_impact": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              }
            ]
          },
          "title": "Estimated Impact",
          "type": "object"
        },
        "proposal_status": {
          "title": "Proposal Status",
          "type": "string"
        },
        "tax_notes": {
          "items": {
            "type": "string"
          },
          "title": "Tax Notes",
          "type": "array"
        },
        "trades": {
          "items": {
            "$ref": "#/$defs/TradeProposal"
          },
          "title": "Trades",
          "type": "array"
        }
      },
      "required": [
        "proposal_status"
      ],
      "title": "ExecutionProposalResponse",
      "type": "object"
    },
    "PolicyVerdictStatus": {
      "enum": [
        "COMPLIANT",
        "NON_COMPLIANT",
        "UNRESOLVED"
      ],
      "title": "PolicyVerdictStatus",
      "type": "string"
    },
    "RecommendationPackage": {
      "additionalProperties": false,
      "properties": {
        "agent_stages": {
          "items": {
            "$ref": "#/$defs/AgentStageResult"
          },
          "title": "Agent Stages",
          "type": "array"
        },
        "approval_eligibility": {
          "title": "Approval Eligibility",
          "type": "boolean"
        },
        "current_allocation": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              }
            ]
          },
          "title": "Current Allocation",
          "type": "object"
        },
        "evidence": {
          "items": {
            "additionalProperties": {
              "type": "string"
            },
            "type": "object"
          },
          "title": "Evidence",
          "type": "array"
        },
        "proposal": {
          "$ref": "#/$defs/ExecutionProposalResponse"
        },
        "proposed_allocation": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              }
            ]
          },
          "title": "Proposed Allocation",
          "type": "object"
        },
        "risk_policy": {
          "$ref": "#/$defs/RiskPolicyResponse"
        },
        "summary": {
          "title": "Summary",
          "type": "string"
        },
        "target_allocation": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              }
            ]
          },
          "title": "Target Allocation",
          "type": "object"
        },
        "workflow_state": {
          "$ref": "#/$defs/WorkflowState"
        }
      },
      "required": [
        "summary",
        "current_allocation",
        "target_allocation",
        "proposed_allocation",
        "risk_policy",
        "proposal",
        "workflow_state",
        "approval_eligibility"
      ],
      "title": "RecommendationPackage",
      "type": "object"
    },
    "RiskPolicyResponse": {
      "additionalProperties": false,
      "properties": {
        "confidence": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              },
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              }
            ]
          },
          "title": "Confidence",
          "type": "object"
        },
        "drift": {
          "items": {
            "$ref": "#/$defs/DriftItem"
          },
          "title": "Drift",
          "type": "array"
        },
        "evidence": {
          "items": {
            "additionalProperties": {
              "type": "string"
            },
            "type": "object"
          },
          "title": "Evidence",
          "type": "array"
        },
        "rule_results": {
          "items": {
            "additionalProperties": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "boolean"
                }
              ]
            },
            "type": "object"
          },
          "title": "Rule Results",
          "type": "array"
        },
        "verdict": {
          "$ref": "#/$defs/PolicyVerdictStatus"
        }
      },
      "required": [
        "verdict",
        "drift"
      ],
      "title": "RiskPolicyResponse",
      "type": "object"
    },
    "TradeAction": {
      "enum": [
        "BUY",
        "SELL",
        "HOLD"
      ],
      "title": "TradeAction",
      "type": "string"
    },
    "TradeProposal": {
      "additionalProperties": false,
      "properties": {
        "action": {
          "$ref": "#/$defs/TradeAction"
        },
        "estimated_value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Estimated Value"
        },
        "evidence_refs": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "rationale": {
          "title": "Rationale",
          "type": "string"
        },
        "symbol": {
          "title": "Symbol",
          "type": "string"
        },
        "trade_id": {
          "title": "Trade Id",
          "type": "string"
        }
      },
      "required": [
        "trade_id",
        "symbol",
        "action",
        "estimated_value",
        "rationale"
      ],
      "title": "TradeProposal",
      "type": "object"
    },
    "WorkflowState": {
      "enum": [
        "NORMAL",
        "DEGRADED",
        "LOW_CONFIDENCE",
        "BLOCKED"
      ],
      "title": "WorkflowState",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "approval_id": {
      "title": "Approval Id",
      "type": "string"
    },
    "approval_status": {
      "default": "PENDING",
      "title": "Approval Status",
      "type": "string"
    },
    "approved_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Approved At"
    },
    "approved_by": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Approved By"
    },
    "correlation": {
      "$ref": "#/$defs/CorrelationMetadata"
    },
    "override_note": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Override Note"
    },
    "recommendation": {
      "$ref": "#/$defs/RecommendationPackage"
    },
    "recommendation_hash": {
      "title": "Recommendation Hash",
      "type": "string"
    },
    "rejection_note": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Rejection Note"
    }
  },
  "required": [
    "approval_id",
    "correlation",
    "recommendation_hash",
    "recommendation"
  ],
  "title": "ApprovalArtifact",
  "type": "object"
}
