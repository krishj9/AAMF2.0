{
  "$defs": {
    "AccountProfile": {
      "additionalProperties": false,
      "properties": {
        "account_id": {
          "title": "Account Id",
          "type": "string"
        },
        "account_type": {
          "$ref": "#/$defs/AccountType",
          "default": "BROKERAGE"
        },
        "base_currency": {
          "default": "USD",
          "maxLength": 3,
          "minLength": 3,
          "title": "Base Currency",
          "type": "string"
        },
        "client_id": {
          "title": "Client Id",
          "type": "string"
        },
        "custodian_label": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Custodian Label"
        },
        "taxable": {
          "default": true,
          "title": "Taxable",
          "type": "boolean"
        }
      },
      "required": [
        "account_id",
        "client_id"
      ],
      "title": "AccountProfile",
      "type": "object"
    },
    "AccountType": {
      "enum": [
        "TAXABLE",
        "IRA",
        "ROTH_IRA",
        "BROKERAGE",
        "OTHER"
      ],
      "title": "AccountType",
      "type": "string"
    },
    "AgentStageResult": {
      "additionalProperties": false,
      "properties": {
        "agent_name": {
          "title": "Agent Name",
          "type": "string"
        },
        "evidence": {
          "items": {
            "additionalProperties": {
              "type": "string"
            },
            "type": "object"
          },
          "title": "Evidence",
          "type": "array"
        },
        "execution_location": {
          "default": "in_process",
          "title": "Execution Location",
          "type": "string"
        },
        "protocol": {
          "default": "LOCAL",
          "title": "Protocol",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/AgentStatus"
        },
        "summary": {
          "title": "Summary",
          "type": "string"
        }
      },
      "required": [
        "agent_name",
        "status",
        "summary"
      ],
      "title": "AgentStageResult",
      "type": "object"
    },
    "AgentStatus": {
      "enum": [
        "PENDING",
        "RUNNING",
        "COMPLETED",
        "DEGRADED",
        "BLOCKED",
        "FAILED"
      ],
      "title": "AgentStatus",
      "type": "string"
    },
    "AllocationTarget": {
      "additionalProperties": false,
      "properties": {
        "account_id": {
          "title": "Account Id",
          "type": "string"
        },
        "asset_class_targets": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              }
            ]
          },
          "title": "Asset Class Targets",
          "type": "object"
        },
        "security_targets": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              }
            ]
          },
          "title": "Security Targets",
          "type": "object"
        },
        "target_id": {
          "title": "Target Id",
          "type": "string"
        },
        "tolerance_bands": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              }
            ]
          },
          "title": "Tolerance Bands",
          "type": "object"
        }
      },
      "required": [
        "target_id",
        "account_id"
      ],
      "title": "AllocationTarget",
      "type": "object"
    },
    "ApprovalArtifact": {
      "additionalProperties": false,
      "properties": {
        "account_profile": {
          "$ref": "#/$defs/AccountProfile"
        },
        "allocation_target": {
          "$ref": "#/$defs/AllocationTarget"
        },
        "approval_id": {
          "title": "Approval Id",
          "type": "string"
        },
        "approval_status": {
          "default": "PENDING",
          "title": "Approval Status",
          "type": "string"
        },
        "approved_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Approved At"
        },
        "approved_by": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Approved By"
        },
        "client_profile": {
          "$ref": "#/$defs/ClientProfile"
        },
        "correlation": {
          "$ref": "#/$defs/CorrelationMetadata"
        },
        "original_portfolio_snapshot": {
          "$ref": "#/$defs/PortfolioSnapshot"
        },
        "override_note": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Override Note"
        },
        "recommendation": {
          "$ref": "#/$defs/RecommendationPackage"
        },
        "recommendation_hash": {
          "title": "Recommendation Hash",
          "type": "string"
        },
        "rejection_note": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Rejection Note"
        },
        "risk_profile": {
          "anyOf": [
            {
              "$ref": "#/$defs/RiskProfile"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "approval_id",
        "correlation",
        "recommendation_hash",
        "recommendation",
        "client_profile",
        "account_profile",
        "original_portfolio_snapshot",
        "allocation_target"
      ],
      "title": "ApprovalArtifact",
      "type": "object"
    },
    "ClientProfile": {
      "additionalProperties": false,
      "properties": {
        "client_id": {
          "title": "Client Id",
          "type": "string"
        },
        "display_label": {
          "title": "Display Label",
          "type": "string"
        },
        "household_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Household Id"
        },
        "risk_profile_id": {
          "title": "Risk Profile Id",
          "type": "string"
        },
        "synthetic": {
          "default": true,
          "title": "Synthetic",
          "type": "boolean"
        },
        "tax_profile_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tax Profile Id"
        }
      },
      "required": [
        "client_id",
        "display_label",
        "risk_profile_id"
      ],
      "title": "ClientProfile",
      "type": "object"
    },
    "CorrelationMetadata": {
      "additionalProperties": false,
      "properties": {
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "idempotency_key": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Idempotency Key"
        },
        "request_id": {
          "title": "Request Id",
          "type": "string"
        },
        "session_id": {
          "title": "Session Id",
          "type": "string"
        },
        "trace_id": {
          "title": "Trace Id",
          "type": "string"
        }
      },
      "title": "CorrelationMetadata",
      "type": "object"
    },
    "DriftItem": {
      "additionalProperties": false,
      "properties": {
        "current_pct": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Current Pct"
        },
        "drift_pct": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Drift Pct"
        },
        "key": {
          "title": "Key",
          "type": "string"
        },
        "target_pct": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Target Pct"
        },
        "tolerance_pct": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Tolerance Pct"
        },
        "within_tolerance": {
          "title": "Within Tolerance",
          "type": "boolean"
        }
      },
      "required": [
        "key",
        "current_pct",
        "target_pct",
        "drift_pct",
        "tolerance_pct",
        "within_tolerance"
      ],
      "title": "DriftItem",
      "type": "object"
    },
    "ErrorSeverity": {
      "enum": [
        "INFO",
        "WARNING",
        "ERROR",
        "CRITICAL"
      ],
      "title": "ErrorSeverity",
      "type": "string"
    },
    "ExecutionProposalResponse": {
      "additionalProperties": false,
      "properties": {
        "confidence": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              },
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              }
            ]
          },
          "title": "Confidence",
          "type": "object"
        },
        "estimated_cost": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "default": "0",
          "title": "Estimated Cost"
        },
        "estimated_impact": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              }
            ]
          },
          "title": "Estimated Impact",
          "type": "object"
        },
        "proposal_status": {
          "title": "Proposal Status",
          "type": "string"
        },
        "tax_notes": {
          "items": {
            "type": "string"
          },
          "title": "Tax Notes",
          "type": "array"
        },
        "trades": {
          "items": {
            "$ref": "#/$defs/TradeProposal"
          },
          "title": "Trades",
          "type": "array"
        }
      },
      "required": [
        "proposal_status"
      ],
      "title": "ExecutionProposalResponse",
      "type": "object"
    },
    "PolicyVerdictStatus": {
      "enum": [
        "COMPLIANT",
        "NON_COMPLIANT",
        "UNRESOLVED"
      ],
      "title": "PolicyVerdictStatus",
      "type": "string"
    },
    "PortfolioHolding": {
      "additionalProperties": false,
      "properties": {
        "as_of": {
          "format": "date-time",
          "title": "As Of",
          "type": "string"
        },
        "asset_class": {
          "default": "unknown",
          "title": "Asset Class",
          "type": "string"
        },
        "cost_basis": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cost Basis"
        },
        "instrument_id": {
          "title": "Instrument Id",
          "type": "string"
        },
        "market_price": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Market Price"
        },
        "market_value": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Market Value"
        },
        "quantity": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Quantity"
        },
        "sector": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sector"
        },
        "symbol": {
          "title": "Symbol",
          "type": "string"
        }
      },
      "required": [
        "instrument_id",
        "symbol",
        "quantity",
        "market_price",
        "market_value",
        "as_of"
      ],
      "title": "PortfolioHolding",
      "type": "object"
    },
    "PortfolioSnapshot": {
      "additionalProperties": false,
      "properties": {
        "account_id": {
          "title": "Account Id",
          "type": "string"
        },
        "allocation": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              }
            ]
          },
          "title": "Allocation",
          "type": "object"
        },
        "as_of": {
          "format": "date-time",
          "title": "As Of",
          "type": "string"
        },
        "cash": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "default": "0",
          "title": "Cash"
        },
        "holdings": {
          "items": {
            "$ref": "#/$defs/PortfolioHolding"
          },
          "minItems": 1,
          "title": "Holdings",
          "type": "array"
        },
        "snapshot_id": {
          "title": "Snapshot Id",
          "type": "string"
        },
        "total_value": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Total Value"
        }
      },
      "required": [
        "snapshot_id",
        "account_id",
        "as_of",
        "holdings",
        "total_value"
      ],
      "title": "PortfolioSnapshot",
      "type": "object"
    },
    "RecommendationPackage": {
      "additionalProperties": false,
      "properties": {
        "agent_stages": {
          "items": {
            "$ref": "#/$defs/AgentStageResult"
          },
          "title": "Agent Stages",
          "type": "array"
        },
        "approval_eligibility": {
          "title": "Approval Eligibility",
          "type": "boolean"
        },
        "current_allocation": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              }
            ]
          },
          "title": "Current Allocation",
          "type": "object"
        },
        "evidence": {
          "items": {
            "additionalProperties": {
              "type": "string"
            },
            "type": "object"
          },
          "title": "Evidence",
          "type": "array"
        },
        "proposal": {
          "$ref": "#/$defs/ExecutionProposalResponse"
        },
        "proposed_allocation": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              }
            ]
          },
          "title": "Proposed Allocation",
          "type": "object"
        },
        "risk_policy": {
          "$ref": "#/$defs/RiskPolicyResponse"
        },
        "summary": {
          "title": "Summary",
          "type": "string"
        },
        "target_allocation": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              }
            ]
          },
          "title": "Target Allocation",
          "type": "object"
        },
        "workflow_state": {
          "$ref": "#/$defs/WorkflowState"
        }
      },
      "required": [
        "summary",
        "current_allocation",
        "target_allocation",
        "proposed_allocation",
        "risk_policy",
        "proposal",
        "workflow_state",
        "approval_eligibility"
      ],
      "title": "RecommendationPackage",
      "type": "object"
    },
    "RiskPolicyResponse": {
      "additionalProperties": false,
      "properties": {
        "confidence": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              },
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              }
            ]
          },
          "title": "Confidence",
          "type": "object"
        },
        "drift": {
          "items": {
            "$ref": "#/$defs/DriftItem"
          },
          "title": "Drift",
          "type": "array"
        },
        "evidence": {
          "items": {
            "additionalProperties": {
              "type": "string"
            },
            "type": "object"
          },
          "title": "Evidence",
          "type": "array"
        },
        "rule_results": {
          "items": {
            "additionalProperties": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "boolean"
                }
              ]
            },
            "type": "object"
          },
          "title": "Rule Results",
          "type": "array"
        },
        "verdict": {
          "$ref": "#/$defs/PolicyVerdictStatus"
        }
      },
      "required": [
        "verdict",
        "drift"
      ],
      "title": "RiskPolicyResponse",
      "type": "object"
    },
    "RiskProfile": {
      "additionalProperties": false,
      "properties": {
        "allowed_asset_classes": {
          "items": {
            "type": "string"
          },
          "title": "Allowed Asset Classes",
          "type": "array"
        },
        "max_sector_pct": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "maximum": 100.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Max Sector Pct"
        },
        "max_single_position_pct": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "maximum": 100.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Max Single Position Pct"
        },
        "risk_level": {
          "title": "Risk Level",
          "type": "string"
        },
        "risk_profile_id": {
          "title": "Risk Profile Id",
          "type": "string"
        }
      },
      "required": [
        "risk_profile_id",
        "risk_level",
        "max_single_position_pct",
        "max_sector_pct"
      ],
      "title": "RiskProfile",
      "type": "object"
    },
    "StructuredError": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "title": "Code",
          "type": "string"
        },
        "correlation": {
          "anyOf": [
            {
              "$ref": "#/$defs/CorrelationMetadata"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "details": {
          "additionalProperties": true,
          "title": "Details",
          "type": "object"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "retryable": {
          "default": false,
          "title": "Retryable",
          "type": "boolean"
        },
        "severity": {
          "$ref": "#/$defs/ErrorSeverity",
          "default": "ERROR"
        },
        "source": {
          "title": "Source",
          "type": "string"
        }
      },
      "required": [
        "code",
        "message",
        "source"
      ],
      "title": "StructuredError",
      "type": "object"
    },
    "TradeAction": {
      "enum": [
        "BUY",
        "SELL",
        "HOLD"
      ],
      "title": "TradeAction",
      "type": "string"
    },
    "TradeProposal": {
      "additionalProperties": false,
      "properties": {
        "action": {
          "$ref": "#/$defs/TradeAction"
        },
        "estimated_value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Estimated Value"
        },
        "evidence_refs": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "rationale": {
          "title": "Rationale",
          "type": "string"
        },
        "symbol": {
          "title": "Symbol",
          "type": "string"
        },
        "trade_id": {
          "title": "Trade Id",
          "type": "string"
        }
      },
      "required": [
        "trade_id",
        "symbol",
        "action",
        "estimated_value",
        "rationale"
      ],
      "title": "TradeProposal",
      "type": "object"
