  "required": [
    "tick_id",
    "as_of",
    "regime",
    "equity_index",
    "equity_change_pct",
    "interest_rate_pct",
    "rate_change_bps",
    "bond_price_index",
    "bond_change_pct",
    "cash_yield_pct"
  ],
  "title": "MarketTick",
  "type": "object"
}
