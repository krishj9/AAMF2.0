{
  "$defs": {
    "PortfolioHolding": {
      "additionalProperties": false,
      "properties": {
        "as_of": {
          "format": "date-time",
          "title": "As Of",
          "type": "string"
        },
        "asset_class": {
          "default": "unknown",
          "title": "Asset Class",
          "type": "string"
        },
        "cost_basis": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cost Basis"
        },
        "instrument_id": {
          "title": "Instrument Id",
          "type": "string"
        },
        "market_price": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Market Price"
        },
        "market_value": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Market Value"
        },
        "quantity": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Quantity"
        },
        "sector": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sector"
        },
        "symbol": {
          "title": "Symbol",
          "type": "string"
        }
      },
      "required": [
        "instrument_id",
        "symbol",
        "quantity",
        "market_price",
        "market_value",
        "as_of"
      ],
      "title": "PortfolioHolding",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "account_id": {
      "title": "Account Id",
      "type": "string"
    },
    "allocation": {
      "additionalProperties": {
        "anyOf": [
          {
            "type": "number"
          },
          {
            "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
            "type": "string"
          }
        ]
      },
      "title": "Allocation",
      "type": "object"
    },
    "as_of": {
      "format": "date-time",
      "title": "As Of",
      "type": "string"
    },
    "cash": {
      "anyOf": [
        {
          "minimum": 0.0,
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        }
      ],
      "default": "0",
      "title": "Cash"
    },
    "holdings": {
      "items": {
        "$ref": "#/$defs/PortfolioHolding"
      },
      "minItems": 1,
      "title": "Holdings",
      "type": "array"
    },
    "snapshot_id": {
      "title": "Snapshot Id",
      "type": "string"
    },
    "total_value": {
      "anyOf": [
        {
          "exclusiveMinimum": 0.0,
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        }
      ],
      "title": "Total Value"
    }
  },
  "required": [
    "snapshot_id",
    "account_id",
    "as_of",
    "holdings",
    "total_value"
  ],
  "title": "PortfolioSnapshot",
  "type": "object"
}
