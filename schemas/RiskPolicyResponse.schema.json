              "type": "string"
            }
          ],
          "title": "Current Pct"
        },
        "drift_pct": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Drift Pct"
        },
        "key": {
          "title": "Key",
          "type": "string"
        },
        "target_pct": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Target Pct"
        },
        "tolerance_pct": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Tolerance Pct"
        },
        "within_tolerance": {
          "title": "Within Tolerance",
          "type": "boolean"
        }
      },
      "required": [
        "key",
        "current_pct",
        "target_pct",
        "drift_pct",
        "tolerance_pct",
        "within_tolerance"
      ],
      "title": "DriftItem",
      "type": "object"
    },
    "PolicyVerdictStatus": {
      "enum": [
        "COMPLIANT",
        "NON_COMPLIANT",
        "UNRESOLVED"
