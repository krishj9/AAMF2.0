          "default": null,
          "title": "Idempotency Key"
        },
        "request_id": {
          "title": "Request Id",
          "type": "string"
        },
        "session_id": {
          "title": "Session Id",
          "type": "string"
        },
        "trace_id": {
          "title": "Trace Id",
          "type": "string"
        }
      },
      "title": "CorrelationMetadata",
      "type": "object"
    },
    "ErrorSeverity": {
