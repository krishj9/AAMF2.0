{
  "$defs": {
    "AccountProfile": {
      "additionalProperties": false,
      "properties": {
        "account_id": {
          "title": "Account Id",
          "type": "string"
        },
        "account_type": {
          "$ref": "#/$defs/AccountType",
          "default": "BROKERAGE"
        },
        "base_currency": {
          "default": "USD",
          "maxLength": 3,
          "minLength": 3,
          "title": "Base Currency",
          "type": "string"
        },
        "client_id": {
          "title": "Client Id",
          "type": "string"
        },
        "custodian_label": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Custodian Label"
        },
        "taxable": {
          "default": true,
          "title": "Taxable",
          "type": "boolean"
        }
      },
      "required": [
        "account_id",
        "client_id"
      ],
      "title": "AccountProfile",
      "type": "object"
    },
    "AccountType": {
      "enum": [
        "TAXABLE",
        "IRA",
        "ROTH_IRA",
        "BROKERAGE",
        "OTHER"
      ],
      "title": "AccountType",
      "type": "string"
    },
    "ActorContext": {
      "additionalProperties": false,
      "properties": {
        "actor_id": {
          "title": "Actor Id",
          "type": "string"
        },
        "auth_provider": {
          "default": "local",
          "title": "Auth Provider",
          "type": "string"
        },
        "display_name": {
          "title": "Display Name",
          "type": "string"
        },
        "is_owner": {
          "default": true,
          "title": "Is Owner",
          "type": "boolean"
        },
        "role": {
          "$ref": "#/$defs/ActorRole",
          "default": "OWNER"
        }
      },
      "required": [
        "actor_id",
        "display_name"
      ],
      "title": "ActorContext",
      "type": "object"
    },
    "ActorRole": {
      "enum": [
        "OWNER",
        "TESTER",
        "VIEWER"
      ],
      "title": "ActorRole",
      "type": "string"
    },
    "AllocationTarget": {
      "additionalProperties": false,
      "properties": {
        "account_id": {
          "title": "Account Id",
          "type": "string"
        },
        "asset_class_targets": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              }
            ]
          },
          "title": "Asset Class Targets",
          "type": "object"
        },
        "security_targets": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              }
            ]
          },
          "title": "Security Targets",
          "type": "object"
        },
        "target_id": {
          "title": "Target Id",
          "type": "string"
        },
        "tolerance_bands": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              }
            ]
          },
          "title": "Tolerance Bands",
          "type": "object"
        }
      },
      "required": [
        "target_id",
        "account_id"
      ],
      "title": "AllocationTarget",
      "type": "object"
    },
    "ClientProfile": {
      "additionalProperties": false,
      "properties": {
        "client_id": {
          "title": "Client Id",
          "type": "string"
        },
        "display_label": {
          "title": "Display Label",
          "type": "string"
        },
        "household_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Household Id"
        },
        "risk_profile_id": {
          "title": "Risk Profile Id",
          "type": "string"
        },
        "synthetic": {
          "default": true,
          "title": "Synthetic",
          "type": "boolean"
        },
        "tax_profile_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tax Profile Id"
        }
      },
      "required": [
        "client_id",
        "display_label",
        "risk_profile_id"
      ],
      "title": "ClientProfile",
      "type": "object"
    },
    "CorrelationMetadata": {
      "additionalProperties": false,
      "properties": {
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "idempotency_key": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Idempotency Key"
        },
        "request_id": {
          "title": "Request Id",
          "type": "string"
        },
        "session_id": {
          "title": "Session Id",
          "type": "string"
        },
        "trace_id": {
          "title": "Trace Id",
          "type": "string"
        }
      },
      "title": "CorrelationMetadata",
      "type": "object"
    },
    "ErrorSeverity": {
      "enum": [
        "INFO",
        "WARNING",
        "ERROR",
        "CRITICAL"
      ],
      "title": "ErrorSeverity",
      "type": "string"
    },
    "PortfolioHolding": {
      "additionalProperties": false,
      "properties": {
        "as_of": {
          "format": "date-time",
          "title": "As Of",
          "type": "string"
        },
        "asset_class": {
          "default": "unknown",
          "title": "Asset Class",
          "type": "string"
        },
        "cost_basis": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cost Basis"
        },
        "instrument_id": {
          "title": "Instrument Id",
          "type": "string"
        },
        "market_price": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Market Price"
        },
        "market_value": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Market Value"
        },
        "quantity": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Quantity"
        },
        "sector": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sector"
        },
        "symbol": {
          "title": "Symbol",
          "type": "string"
        }
      },
      "required": [
        "instrument_id",
        "symbol",
        "quantity",
        "market_price",
        "market_value",
        "as_of"
      ],
      "title": "PortfolioHolding",
      "type": "object"
    },
    "PortfolioRebalanceRequest": {
      "additionalProperties": false,
      "properties": {
        "account_profile": {
          "$ref": "#/$defs/AccountProfile"
        },
        "actor": {
          "$ref": "#/$defs/ActorContext"
        },
        "allocation_target": {
          "$ref": "#/$defs/AllocationTarget"
        },
        "client_profile": {
          "$ref": "#/$defs/ClientProfile"
        },
        "constraints": {
          "additionalProperties": true,
          "title": "Constraints",
          "type": "object"
        },
        "correlation": {
          "$ref": "#/$defs/CorrelationMetadata"
        },
        "portfolio_snapshot": {
          "$ref": "#/$defs/PortfolioSnapshot"
        },
        "requested_action_context": {
          "default": "rebalance_review",
          "title": "Requested Action Context",
          "type": "string"
        },
        "risk_profile": {
          "anyOf": [
            {
              "$ref": "#/$defs/RiskProfile"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "version": {
          "$ref": "#/$defs/VersionMetadata"
        }
      },
      "required": [
        "actor",
        "client_profile",
        "account_profile",
        "portfolio_snapshot",
        "allocation_target"
      ],
      "title": "PortfolioRebalanceRequest",
      "type": "object"
    },
    "PortfolioSnapshot": {
      "additionalProperties": false,
      "properties": {
        "account_id": {
          "title": "Account Id",
          "type": "string"
        },
        "allocation": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              }
            ]
          },
          "title": "Allocation",
          "type": "object"
        },
        "as_of": {
          "format": "date-time",
          "title": "As Of",
          "type": "string"
        },
        "cash": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "default": "0",
          "title": "Cash"
        },
        "holdings": {
          "items": {
            "$ref": "#/$defs/PortfolioHolding"
          },
          "minItems": 1,
          "title": "Holdings",
          "type": "array"
        },
        "snapshot_id": {
          "title": "Snapshot Id",
          "type": "string"
        },
        "total_value": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Total Value"
        }
      },
      "required": [
        "snapshot_id",
        "account_id",
        "as_of",
        "holdings",
        "total_value"
      ],
      "title": "PortfolioSnapshot",
      "type": "object"
    },
    "RiskProfile": {
      "additionalProperties": false,
      "properties": {
        "allowed_asset_classes": {
          "items": {
            "type": "string"
          },
          "title": "Allowed Asset Classes",
          "type": "array"
        },
        "max_sector_pct": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "maximum": 100.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Max Sector Pct"
        },
        "max_single_position_pct": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "maximum": 100.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Max Single Position Pct"
        },
        "risk_level": {
          "title": "Risk Level",
          "type": "string"
        },
        "risk_profile_id": {
          "title": "Risk Profile Id",
          "type": "string"
        }
      },
      "required": [
        "risk_profile_id",
        "risk_level",
        "max_single_position_pct",
        "max_sector_pct"
      ],
      "title": "RiskProfile",
      "type": "object"
    },
    "StructuredError": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "title": "Code",
          "type": "string"
        },
        "correlation": {
          "anyOf": [
            {
              "$ref": "#/$defs/CorrelationMetadata"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "details": {
          "additionalProperties": true,
          "title": "Details",
          "type": "object"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "retryable": {
          "default": false,
          "title": "Retryable",
          "type": "boolean"
        },
        "severity": {
          "$ref": "#/$defs/ErrorSeverity",
          "default": "ERROR"
        },
        "source": {
          "title": "Source",
          "type": "string"
        }
      },
      "required": [
        "code",
        "message",
        "source"
      ],
      "title": "StructuredError",
      "type": "object"
    },
    "VersionMetadata": {
      "additionalProperties": false,
      "properties": {
        "agent_version_set": {
          "default": "local-dev",
          "title": "Agent Version Set",
          "type": "string"
        },
        "app_version": {
          "default": "0.1.0",
          "title": "App Version",
          "type": "string"
        },
        "environment": {
          "default": "dev",
          "title": "Environment",
          "type": "string"
        },
        "policy_version": {
          "default": "1.0.0",
          "title": "Policy Version",
          "type": "string"
        },
        "schema_version": {
          "default": "1.0.0",
          "title": "Schema Version",
          "type": "string"
        }
      },
      "title": "VersionMetadata",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "actor": {
      "$ref": "#/$defs/ActorContext"
    },
    "correlation": {
      "$ref": "#/$defs/CorrelationMetadata"
    },
    "errors": {
      "items": {
        "$ref": "#/$defs/StructuredError"
      },
      "title": "Errors",
      "type": "array"
    },
    "guardrail_result": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Guardrail Result"
    },
    "memory": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Memory"
    },
    "proposal": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Proposal"
    },
    "quality": {
      "additionalProperties": true,
      "title": "Quality",
      "type": "object"
    },
    "request": {
      "$ref": "#/$defs/PortfolioRebalanceRequest"
    },
    "research": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Research"
    },
    "risk_policy": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Risk Policy"
    },
    "version": {
      "$ref": "#/$defs/VersionMetadata"
    }
  },
  "required": [
    "correlation",
    "version",
    "actor",
    "request"
  ],
  "title": "GraphState",
  "type": "object"
}
